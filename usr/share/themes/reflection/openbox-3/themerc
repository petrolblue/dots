!! Global
*.text.justify: center
window.handle.width: 10
window.client.padding.width: 0
window.client.padding.height: 0
border.Width: 3
padding.width: 20

!! Menu
menu.overlap.x: -30
menu.overlap: 0
menu.border.color: #222222
menu.title.text.justify: center
menu.title.bg: flat solid
menu.title.bg.color: #f4f4f4
menu.title.text.color: #222222
menu.items.bg: flat solid
menu.items.bg.color: #f4f4f4
menu.items.text.color: #222222
menu.items.disabled.text.color: #555555
menu.items.active.bg: flat solid
menu.items.active.bg.color:  #222222
menu.items.active.text.color: #f4f4f4
menu.separator.padding.height: 5
menu.separator.padding.width: 5

!! Active Windows
window.active.title.bg: flat solid
window.active.title.bg.color: #f4f4f4
window.active.label.bg: parentrelative
window.active.label.text.color: #222222
window.active.button.*.bg: parentrelative
window.active.button.*.image.color: #222222
window.active.border.color: #222222

!! Inactive Windows
window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #f4f4f4
window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #222222
window.inactive.button.*.bg: parentrelative
window.inactive.button.*.image.color:  #222222
window.inactive.border.color: #222222

!! handle and grip
*.handle.bg: flat
*.handle.bg.color: #f4f4f4
*.grip.bg: flat
*.grip.bg.color: #f4f4f4
