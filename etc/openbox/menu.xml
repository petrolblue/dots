<?xml version="1.0" encoding="utf-8"?>
<openbox_menu xmlns="http://openbox.org/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://openbox.org/                 file:///usr/share/openbox/menu.xsd">
	<menu id="root-menu" label="openbox">
		<item label="term">
			<action name="Execute">
				<execute>kitty</execute>
			</action>
		</item>
		<item label="chat">
			<action name="Execute">
				<execute>Discord</execute>
			</action>
		</item>
		<item label="www">
			<action name="Execute">
				<execute>firefox</execute>
			</action>
		</item>
		<item label="read">
			<action name="Execute">
				<execute>zathura</execute>
			</action>
		</item>
		<separator/>
		<menu id="power" label="power" >
			<item label="reboot">
				<action name="Execute">
					<execute>systemctl reboot</execute>
				</action>
			</item>
			<item label="poweroff">
				<action name="Execute">
					<execute>systemctl poweroff</execute>
				</action>
			</item>
		</menu>
		<seperator/>
		<menu id="openbox" label="openbox">
			<item label="exit">
				<action name="Exit"/>
			</item>
			<item label="reload">
				<action name="Restart"/>
			</item>
		</menu>
	</menu>
</openbox_menu>
